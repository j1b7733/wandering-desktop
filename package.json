{
  "name": "wandering-desktop",
  "private": true,
  "version": "1.1.0",
  "description": "Wandering Desktop - Track and photo viewer for Wandering outings",
  "author": "Wandering",
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.wandering.desktop",
    "productName": "Wandering Desktop",
    "files": [
      "dist/renderer/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "exifr": "^7.1.3",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "leaflet-editable": "^1.3.2",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4"
  }
}
